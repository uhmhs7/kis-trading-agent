# KIS_ENV can be mock, paper, or prod.
# mock works without real credentials and is the default.
KIS_ENV=mock

# Live KIS app credentials
KIS_APP_KEY=
KIS_APP_SECRET=

# Paper KIS app credentials
KIS_PAPER_APP_KEY=
KIS_PAPER_APP_SECRET=

# KIS account numbers use the 8-digit account body and 2-digit product code separately.
KIS_ACCOUNT_NO=
KIS_PAPER_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_HTS_ID=

# Safety switches
KIS_ALLOW_LIVE_ORDERS=false
KIS_MAX_ORDER_KRW=50000
KIS_DAILY_LOSS_LIMIT_KRW=10000
KIS_MAX_POSITION_PCT=0.20
# Reference equity for the single-name weight check and the mock portfolio's cash.
KIS_BASE_EQUITY_KRW=1000000
# US (USD) account limits — overseas counterpart of the KRW limits above.
KIS_MAX_ORDER_USD=50
KIS_DAILY_LOSS_LIMIT_USD=10
KIS_BASE_EQUITY_USD=1000
KIS_ALLOWED_SYMBOLS=
KIS_LIVE_CONFIRM_TEXT=EXECUTE_LIVE_ORDER

# Optional operator secret you choose yourself (e.g. `openssl rand -hex 32`).
# When set, order/balance endpoints AND runtime env switching (paper/prod) require
# the matching X-Dashboard-Token header. Leave empty for the open mock demo
# (then only mock is reachable and order/balance stay public).
DASHBOARD_TOKEN=

# LLM agent (optional). Without a key, chat falls back to a keyword router.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Adaptive thinking default (UI can toggle at runtime). Applies to thinking-capable
# models (Opus/Sonnet); ignored for Haiku.
ANTHROPIC_THINKING=false
LLM_MAX_STEPS=6

# Auto-trading is toggled at runtime in the UI (stored in data/runtime_config.json),
# OFF by default. mock/paper carry no real money so they run fully autonomously;
# only prod real orders need KIS_ALLOW_LIVE_ORDERS + confirm text. LLM-mode autopilot
# requires DASHBOARD_TOKEN (autonomous paid calls).

# App behavior
DEFAULT_WATCHLIST=005930,000660,035420,051910,005380
DATA_DIR=data

